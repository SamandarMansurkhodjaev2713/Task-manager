# Copy to .env and fill in values. See comments in .env.example or README.

TELEGRAM_BOT_TOKEN=

# Optional employee directory source.
# Leave GOOGLE_SHEETS_ID and auth values empty for local/personal testing:
# users who complete /start are created as bot_registered employees and can be
# assigned tasks by full name. Set these only when a real Google Sheet exists.
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_RANGE=Employees!A:F
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_BEARER_TOKEN=
# Optional test/demo fallback used only when GOOGLE_SHEETS_ID/auth are empty.
# Empty by default so production deployments do NOT auto-populate fake test
# employees.  Uncomment with `docs/google-sheets-test-employees.csv` to load
# the bundled demo roster (six fake employees) for local exploration.
LOCAL_EMPLOYEE_DIRECTORY_CSV_PATH=
# Optional: A1 notation range to append bot-registered users back into the sheet.
# Requires GOOGLE_SHEETS_BEARER_TOKEN (OAuth). Leave empty to disable write-back.
# Example: GOOGLE_SHEETS_WRITE_BACK_RANGE=Employees!A:G
GOOGLE_SHEETS_WRITE_BACK_RANGE=
GOOGLE_GEMINI_API_KEY=replace_me
GOOGLE_GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=replace_me
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
DATABASE_URL=sqlite://./data/app.db
BIND_ADDRESS=0.0.0.0:8080
RUST_LOG=info,telegram_task_bot=debug
EMPLOYEE_SYNC_INTERVAL_MINUTES=60
NOTIFICATION_POLL_INTERVAL_SECONDS=30
REMINDER_TICK_SECONDS=60
DEADLINE_REMINDER_HOUR_UTC=9
OVERDUE_SCAN_HOUR_UTC=10
DAILY_SUMMARY_HOUR_UTC=8
# Max Telegram messages per user per minute before rate-limiting kicks in (default: 20)
RATE_LIMIT_PER_MINUTE=20

# ── One-shot employee directory reset ─────────────────────────────────────
# Set to `true` for a single boot to wipe the entire `employees` table
# (and its dependent indexes / sync queues / aliases / history) before the
# initial Sheets/CSV sync runs.  Existing tasks have their
# `assigned_to_employee_id` nulled so they remain readable.
# REMEMBER to flip this back to `false` after the boot finishes — leaving
# it `true` will wipe employees on every restart.
RESET_EMPLOYEES_ON_STARTUP=false

# ── RBAC / Admin bootstrapping ────────────────────────────────────────────
# Comma-separated list of Telegram IDs that should be automatically
# promoted to the `Admin` role at every process start.  Users that
# appear here but have not yet sent `/start` will be silently skipped
# and promoted on their next interaction.  The list is additive — removing
# a user from here does NOT demote them; use /admin inside Telegram for
# demotion so the last-admin invariant is enforced.
# Example: TELEGRAM_ADMIN_IDS=123456789,987654321
TELEGRAM_ADMIN_IDS=

# TTL (seconds) for admin panel confirmation nonces.  Short windows
# shrink the replay surface for destructive buttons.  Default: 120.
ADMIN_NONCE_TTL_SECONDS=120

# Comma-separated list of feature flags enabled from startup. Unknown
# flags are logged and ignored so older releases can survive newer DB values.
#
# Known flags (snake_case, matching `FeatureFlag` enum variants):
#   onboarding_v2    — FSM-based registration (first name / last name / employee link)
#   admin_panel      — /admin panel and role management
#   sla_escalations  — SLA breach escalations and warnings
#   voice_v2         — voice-to-task state machine (skeleton; reserved for Phase 3)
#   task_templates   — task templates
#   recurrence_rules — recurring task rules
#   team_analytics   — team-wide analytics widgets (DEFAULT ON for managers)
#
# Defaults (compiled in): onboarding_v2, admin_panel, team_analytics.
#
# Example: FEATURE_FLAGS=onboarding_v2,admin_panel,team_analytics,voice_v2
FEATURE_FLAGS=onboarding_v2,admin_panel,team_analytics
